#!/bin/bash
# TryHackMe VPN Manager

VPN_CONFIG="{{ homelab_dir }}/vpn/thm.ovpn"
LOG_FILE="/tmp/thm-vpn.log"

case "$1" in
    start)
        if [ ! -f "$VPN_CONFIG" ]; then
            echo "❌ THM VPN config not found: $VPN_CONFIG"
            echo ""
            echo "Download from: https://tryhackme.com/access"
            echo "Save to: $VPN_CONFIG"
            exit 1
        fi
        
        echo "🔒 Starting TryHackMe VPN..."
        sudo openvpn --config "$VPN_CONFIG" --daemon --log "$LOG_FILE"
        
        sleep 3
        
        if ip addr show tun0 &> /dev/null; then
            echo "✅ VPN connected!"
            echo ""
            echo "VPN IP: $(ip addr show tun0 | grep "inet " | awk '{print $2}')"
        else
            echo "❌ VPN connection failed. Check log: $LOG_FILE"
            exit 1
        fi
        ;;
        
    stop)
        echo "🛑 Stopping VPN..."
        sudo killall openvpn
        echo "✅ VPN disconnected"
        ;;
        
    status)
        if pgrep openvpn > /dev/null; then
            echo "✅ THM VPN is running"
            if ip addr show tun0 &> /dev/null; then
                echo "VPN IP: $(ip addr show tun0 | grep "inet " | awk '{print $2}')"
            fi
        else
            echo "❌ THM VPN is not running"
        fi
        ;;
        
    restart)
        $0 stop
        sleep 2
        $0 start
        ;;
        
    *)
        echo "TryHackMe VPN Manager"
        echo ""
        echo "Usage: $0 {start|stop|status|restart}"
        exit 1
        ;;
esac
