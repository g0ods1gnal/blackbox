/* Wofi - Gruvbox Hard Dark Theme */

window {
    margin: 0px;
    border: 2px solid {{ gruvbox.blue_dark }};
    background-color: {{ gruvbox.bg_hard }};
    border-radius: 8px;
}

#input {
    margin: 10px;
    padding: 10px;
    border: 2px solid {{ gruvbox.blue_dark }};
    color: {{ gruvbox.fg }};
    background-color: {{ gruvbox.bg }};
    border-radius: 4px;
}

#inner-box {
    margin: 10px;
    background-color: {{ gruvbox.bg_hard }};
}

#outer-box {
    margin: 0px;
    background-color: {{ gruvbox.bg_hard }};
}

#scroll {
    margin: 0px;
}

#text {
    margin: 5px;
    color: {{ gruvbox.fg }};
}

#entry:selected {
    background-color: {{ gruvbox.blue_dark }};
    color: {{ gruvbox.bg_hard }};
    border-radius: 4px;
}

#entry:selected #text {
    color: {{ gruvbox.bg_hard }};
    font-weight: bold;
}

#text:selected {
    color: {{ gruvbox.bg_hard }};
}
