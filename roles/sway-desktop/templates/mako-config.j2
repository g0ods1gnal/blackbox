# Mako - Gruvbox Hard Dark Theme
# Auto-generated by Ansible

font=JetBrainsMono Nerd Font 11
background-color={{ gruvbox.bg_hard }}
text-color={{ gruvbox.fg }}
border-color={{ gruvbox.blue_dark }}
border-size=2
border-radius=8
padding=15
margin=10
default-timeout=5000
ignore-timeout=0

[urgency=low]
border-color={{ gruvbox.green_dark }}
background-color={{ gruvbox.bg_hard }}

[urgency=normal]
border-color={{ gruvbox.blue_dark }}
background-color={{ gruvbox.bg_hard }}

[urgency=high]
border-color={{ gruvbox.red_dark }}
background-color={{ gruvbox.bg_hard }}
default-timeout=0
