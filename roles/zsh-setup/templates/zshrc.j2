# Auto-generated by Ansible

# Enable Powerlevel10k instant prompt
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Path to Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"

# Theme
ZSH_THEME="powerlevel10k/powerlevel10k"

# Plugins
plugins=(
    git
    docker
    kubectl
    ansible
    sudo
    zsh-autosuggestions
    zsh-syntax-highlighting
    colored-man-pages
    command-not-found
)

source $ZSH/oh-my-zsh.sh

# Powerlevel10k config
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# ============================================
# CUSTOM CONFIGURATION
# ============================================

# Gruvbox colors for autosuggestions
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg={{ gruvbox.gray }}'

# History
HISTSIZE=10000
SAVEHIST=10000
HISTFILE=~/.zsh_history
setopt SHARE_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS

# ============================================
# LAB MANAGEMENT
# ============================================
alias lab-start='~/homelab/scripts/lab-start.sh'
alias lab-stop='~/homelab/scripts/post-op-clean.sh'
alias lab-check='~/homelab/scripts/pre-op-check.sh'

# VPN
alias htb='~/homelab/scripts/htb-vpn.sh'
alias thm='~/homelab/scripts/thm-vpn.sh'

# VMs
alias vms='sudo virsh list --all'
alias vm-start='sudo virsh start'
alias vm-stop='sudo virsh shutdown'

# ============================================
# SECURITY TOOLS
# ============================================
# Network
alias myip='curl -s ifconfig.me'
alias localip='ip addr show | grep "inet " | grep -v 127.0.0.1'
alias ports='sudo netstat -tulanp'
alias listening='sudo lsof -i -P -n | grep LISTEN'
alias vpncheck='ip addr show tun0 2>/dev/null || echo "No VPN connected"'

# Firewall
alias fwstatus='sudo ufw status verbose'

# Tools
alias nse='ls /usr/share/nmap/scripts/ | grep'
alias portscan='nmap -sV -sC -oN'
alias hashid='hashcat --identify'

# ============================================
# QUALITY OF LIFE
# ============================================
# Better ls
if command -v eza > /dev/null 2>&1; then
    alias ls='eza --icons --color=always --group-directories-first'
    alias ll='eza -la --icons --color=always --group-directories-first'
    alias la='eza -a --icons --color=always --group-directories-first'
    alias lt='eza -T --icons --color=always --group-directories-first'
else
    alias ll='ls -lah'
    alias la='ls -A'
fi

# Better cat
if command -v bat > /dev/null 2>&1; then
    alias cat='bat --paging=never --style=plain'
    alias catt='bat --paging=always'
fi

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias homelab='cd ~/homelab'
alias lab='cd ~/lab'
alias htbdir='cd ~/HTB/Active'
alias vault='cd ~/Documents/Vault'

# ============================================
# ENVIRONMENT
# ============================================
# Editor
export EDITOR='nvim'
export VISUAL='nvim'

# Path
export PATH="$HOME/.local/bin:$PATH"

# Target management
export TARGET=""
set-target() {
    export TARGET=$1
    echo "Target set to: $TARGET"
}
alias t='echo $TARGET'

# ============================================
# FUNCTIONS
# ============================================
# Quick nmap scan
qscan() {
    if [ -z "$1" ]; then
        echo "Usage: qscan <ip>"
        return 1
    fi
    nmap -sV -sC -oN quick-scan-$(date +%Y%m%d-%H%M%S).nmap $1
}

# Extract archives
extract() {
    if [ -f $1 ]; then
        case $1 in
            *.tar.bz2)   tar xjf $1     ;;
            *.tar.gz)    tar xzf $1     ;;
            *.bz2)       bunzip2 $1     ;;
            *.rar)       unrar e $1     ;;
            *.gz)        gunzip $1      ;;
            *.tar)       tar xf $1      ;;
            *.tbz2)      tar xjf $1     ;;
            *.tgz)       tar xzf $1     ;;
            *.zip)       unzip $1       ;;
            *.Z)         uncompress $1  ;;
            *.7z)        7z x $1        ;;
            *)           echo "'$1' cannot be extracted" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}

# Docker lab
dlab() {
    ~/homelab/scripts/docker-lab.sh $1
}

